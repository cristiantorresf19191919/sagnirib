{
  "name": "biringas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "seo:audit": "node scripts/audit-seo.mjs",
    "design:audit": "node scripts/audit-design.mjs",
    "security:audit": "node scripts/audit-security.mjs",
    "patterns:audit": "node scripts/audit-patterns.mjs",
    "responsive:audit": "node scripts/audit-responsive.mjs",
    "firebase:audit": "node scripts/audit-firebase.mjs",
    "responsive:e2e": "playwright test --project=responsive",
    "seed:firebase": "tsx --conditions=react-server scripts/seed-firebase.ts",
    "seed:firebase:dry": "tsx --conditions=react-server scripts/seed-firebase.ts --dry-run",
    "firebase:deploy:rules": "pnpm dlx firebase-tools@latest deploy --only firestore:rules",
    "firebase:deploy:indexes": "pnpm dlx firebase-tools@latest deploy --only firestore:indexes",
    "firebase:deploy:storage": "pnpm dlx firebase-tools@latest deploy --only storage",
    "firebase:deploy": "pnpm dlx firebase-tools@latest deploy --only firestore,storage"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
