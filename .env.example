# Copy to .env.local and fill in values. Never commit .env.local.
# .env* is gitignored.

# --- Public site config ---
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_APP_ENV=development

# --- Firebase Web SDK (PUBLIC by design) ---
# Inlined into the client bundle by Next.js. Security comes from Firebase
# Auth rules + App Check, NOT from hiding these values.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# --- Firebase Admin (SERVER ONLY — real secrets) ---
# Read only in src/core/config/firebase.ts. Must NEVER be referenced with the
# NEXT_PUBLIC_ prefix or read from client/edge code.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full PEM private key as one line, with literal "\n" between lines.
FIREBASE_PRIVATE_KEY=

# --- Firebase Cloud Storage (SERVER ONLY) ---
# Bucket the wizard uploads photos to. For legacy projects the value is
# `<projectId>.appspot.com`; for projects created after Oct 2024 it is
# `<projectId>.firebasestorage.app`. The bucket is denied to the client SDK
# (see storage.rules) — all access goes through signed URLs issued by
# Server Actions. Read only in src/core/config/firebase.ts.
FIREBASE_STORAGE_BUCKET=
